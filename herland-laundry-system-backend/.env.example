# =============================================================
# Herland Laundry System — Backend Environment Variables
# =============================================================
# Copy this file to .env and fill in the actual values.
#   cp .env.example .env
# NEVER commit the .env file to git.
# =============================================================

# ── Server ─────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Supabase ───────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Google Maps (if used server-side) ──────────────────────────
VITE_GOOGLE_MAPS_API_KEY=

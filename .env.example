# =============================================================
# Herland Laundry System — Root Environment Variables
# =============================================================
# These variables are used by docker-compose.yml (production profile)
# to pass build-time args into the frontend container.
#
# Copy this file to .env and fill in the actual values:
#   cp .env.example .env
# NEVER commit the .env file to git.
# =============================================================

# ── Frontend build args (baked into the static bundle) ─────────
VITE_API_URL=http://localhost:5000/api/v1
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_GOOGLE_MAPS_API_KEY=
